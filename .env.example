# Auth session signing secret (required in production)
AUTH_SECRET=change-me-to-a-long-random-string

# NextAuth (required for /login and header auth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string
# Can reuse AUTH_SECRET if already set:
# AUTH_SECRET=change-me-to-a-long-random-string

# Production (Vercel Dashboard):
# NEXTAUTH_URL=https://rehouse.co.il
# NEXTAUTH_SECRET=<same value as AUTH_SECRET or openssl rand -base64 32>

# Google OAuth (optional — leave empty to disable Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Supabase for production property storage
# When both are set, catalog properties use Supabase instead of data/catalog-properties.json
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Sheets + Drive sync (service account with read access to sheet + media folder)
GOOGLE_SHEETS_ID=1-5ucjjhZlFKzS6xhdJDiJZeYERlR3FpkUUkeAh9fm88
GOOGLE_SHEETS_PROPERTIES_GID=1128361858
# Optional separate tab for agent profile updates
# GOOGLE_SHEETS_AGENTS_GID=
GOOGLE_DRIVE_MEDIA_FOLDER_ID=1kycNEfLyb07auk5KfKARZCaTyzfFkyF_

# Option A — full JSON key inline (recommended on Vercel)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"..."}

# Option A2 — path to JSON key file (recommended locally)
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/absolute/path/to/service-account.json

# Option B — split credentials
# GOOGLE_SERVICE_ACCOUNT_EMAIL=sync@your-project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional CLI sync secret (allows npm run properties:sync-google without login)
# PROPERTY_SYNC_SECRET=dev-sync-secret

# ISR — seconds between automatic revalidation (default: 300)
# REVALIDATE_SECONDS=300

# On-demand revalidation secret for Make/n8n/Dror webhooks → POST /api/revalidate
# REVALIDATION_SECRET=your-long-random-secret

# Forward lead submissions to Make/n8n automation
# LEADS_WEBHOOK_URL=https://hook.eu1.make.com/your-webhook-id
